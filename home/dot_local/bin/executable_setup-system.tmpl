#!/usr/bin/env bash
# System setup helper - automated system configuration after chezmoi apply
# Supports: macOS, Fedora, Ubuntu
# Idempotent: safe to run multiple times

set -euo pipefail

readonly CHEZMOI_ENV="{{ .env }}"

# Set INSTALL_UI_APPS=true to install optional desktop applications on Linux.
# The ubuntu-agent environment always skips desktop/UI packages.
INSTALL_UI_APPS="${INSTALL_UI_APPS:-false}"

# Terminal colors
readonly RED='\033[0;31m'
readonly GREEN='\033[0;32m'
readonly YELLOW='\033[1;33m'
readonly BLUE='\033[0;34m'
readonly NC='\033[0m'

log_info() {
  echo -e "${BLUE}==>${NC} $*"
}

log_success() {
  echo -e "${GREEN}==>${NC} $*"
}

log_warn() {
  echo -e "${YELLOW}WARNING:${NC} $*" >&2
}

log_error() {
  echo -e "${RED}ERROR:${NC} $*" >&2
}

die() {
  log_error "$*"
  exit 1
}

command_exists() {
  command -v "$1" >/dev/null 2>&1
}

# Reapply PATH and tool env in this bash process after installs (brew/mise/curl installers).
refresh_shell_environment() {
  local platform="${1:-}"

  case ":${PATH:-}:" in
 *":${HOME}/.local/bin:"*) ;;
  *) export PATH="${HOME}/.local/bin:${PATH:-}" ;;
  esac

  if [[ "$platform" == "macos" ]]; then
    if [[ -x /opt/homebrew/bin/brew ]]; then
      # shellcheck disable=SC2312
      eval "$(/opt/homebrew/bin/brew shellenv bash)"
    elif [[ -x /usr/local/bin/brew ]]; then
      # shellcheck disable=SC2312
      eval "$(/usr/local/bin/brew shellenv bash)"
    elif command_exists brew; then
      # shellcheck disable=SC2312
      eval "$(brew shellenv bash)"
    fi
  elif [[ "$platform" != "macos" ]] && [[ -x /home/linuxbrew/.linuxbrew/bin/brew ]]; then
    # shellcheck disable=SC2312
    eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv bash)"
  fi

  if command_exists mise; then
    # shellcheck disable=SC2312
    eval "$(mise env -s bash)" 2>/dev/null || true
  fi
}

should_install_ui_apps() {
  [[ "$CHEZMOI_ENV" != "ubuntu-agent" && "$INSTALL_UI_APPS" == "true" ]]
}

detect_platform() {
  case "$(uname -s)" in
  Darwin)
    echo "macos"
    ;;
  Linux)
    if [[ -f /etc/os-release ]]; then
      # shellcheck disable=SC1091
      . /etc/os-release
      case "${ID:-}" in
      fedora)
        echo "fedora"
        return 0
        ;;
      ubuntu)
        echo "ubuntu"
        return 0
        ;;
      *)
        die "Unsupported Linux distribution. This script supports Fedora and Ubuntu only."
        ;;
      esac
    fi

    die "Unsupported Linux distribution. This script supports Fedora and Ubuntu only."
    ;;
  *)
    die "Unsupported platform. This script supports macOS, Fedora, and Ubuntu only."
    ;;
  esac
}

setup_homebrew() {
  log_info "Setting up Homebrew..."

  if command_exists brew; then
    log_success "Homebrew already installed: $(brew --version | head -n1)"
    eval "$(brew shellenv)"
    return 0
  fi

  log_info "Installing Homebrew..."
  if ! /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"; then
    die "Homebrew installation failed"
  fi

  # Bootstrap Homebrew into current shell
  case "$(uname -m)" in
  arm64)
    eval "$(/opt/homebrew/bin/brew shellenv)"
    ;;
  *)
    eval "$(/usr/local/bin/brew shellenv)"
    ;;
  esac

  if command_exists brew; then
    log_success "Homebrew installed: $(brew --version | head -n1)"
  else
    die "Homebrew installation completed but brew command not found"
  fi
}

install_system_packages() {
  local platform="$1"

  log_info "Installing system packages..."

  case "$platform" in
  macos)
    eval "$(brew shellenv)"
    local packages=()
    for pkg in zsh rbw; do
      brew list "$pkg" &>/dev/null || packages+=("$pkg")
    done
    [[ ${#packages[@]} -gt 0 ]] && brew install "${packages[@]}"

    if [[ "$CHEZMOI_ENV" == "ubuntu-agent" ]]; then
      log_info "Skipping desktop UI applications for ubuntu-agent environment"
    else
      local casks=()
      for cask in kitty font-fira-code; do
        brew list --cask "$cask" &>/dev/null || casks+=("$cask")
      done
      [[ ${#casks[@]} -gt 0 ]] && brew install --cask "${casks[@]}"
    fi
    ;;
  fedora)
    local packages=(zsh rbw)
    local ui_packages=(kitty fira-code-fonts)

    sudo dnf install -y "${packages[@]}" || die "dnf package installation failed"

    if should_install_ui_apps; then
      sudo dnf install -y "${ui_packages[@]}" || die "dnf UI package installation failed"
    else
      log_info "Skipping optional UI applications on Fedora"
    fi
    ;;
  ubuntu)
    local packages=(zsh)
    local ui_packages=(kitty fonts-firacode)

    if apt-cache show rbw >/dev/null 2>&1; then
      packages+=(rbw)
    else
      log_warn "rbw package not available via apt on this Ubuntu release; skipping package install"
    fi

    sudo apt-get update || die "apt-get update failed"
    sudo apt-get install -y "${packages[@]}" || die "apt package installation failed"

    if should_install_ui_apps; then
      sudo apt-get install -y "${ui_packages[@]}" || die "apt UI package installation failed"
    else
      log_info "Skipping optional UI applications on Ubuntu"
    fi
    ;;
  esac

  refresh_shell_environment "$platform"
  log_success "System packages installed"
}

configure_rbw() {
  log_info "Configuring rbw (Bitwarden CLI)..."

  if ! command_exists rbw; then
    log_warn "rbw not found, skipping Bitwarden CLI configuration"
    return 0
  fi

  local current_email
  current_email="$(rbw config show 2>/dev/null | grep -o '"email": *"[^"]*"' | cut -d'"' -f4)"

  if [[ -n "$current_email" ]]; then
    log_success "rbw already configured with email: $current_email"
    return 0
  fi

  local bitwarden_email
  read -rp "Enter your Bitwarden email: " bitwarden_email

  if [[ -z "$bitwarden_email" ]]; then
    log_warn "No email provided, skipping rbw configuration"
    return 0
  fi

  if ! rbw config set email "$bitwarden_email"; then
    die "Failed to configure rbw with email: $bitwarden_email"
  fi

  log_success "rbw configured with email: $bitwarden_email"
}

install_opencode() {
  local platform="$1"

  log_info "Installing OpenCode..."

  if command_exists opencode; then
    log_success "OpenCode already installed: $(opencode --version 2>/dev/null || echo 'version unknown')"
    return 0
  fi

  log_info "Installing OpenCode via official installer..."
  if ! curl -fsSL https://opencode.ai/install | bash; then
    die "OpenCode installation failed"
  fi

  refresh_shell_environment "$platform"

  if command_exists opencode; then
    log_success "OpenCode installed: $(opencode --version 2>/dev/null || echo 'installed successfully')"
  else
    die "OpenCode installation completed but command not found"
  fi
}

install_mise() {
  local platform="$1"

  log_info "Installing mise..."

  if command_exists mise && mise --version | grep -q "^mise [0-9]"; then
    log_success "mise already installed: $(mise --version)"
    return 0
  fi

  case "$platform" in
  macos)
    eval "$(brew shellenv)"
    if ! brew list mise &>/dev/null; then
      brew install mise || die "mise installation failed"
    fi
    ;;
  fedora)
    log_info "Installing mise via official installer..."
    if ! curl -fsSL https://mise.run | sh; then
      die "mise installation failed"
    fi
    ;;
  ubuntu)
    log_info "Installing mise via official installer..."
    if ! curl -fsSL https://mise.run | sh; then
      die "mise installation failed"
    fi
    ;;
  esac

  refresh_shell_environment "$platform"

  if command_exists mise; then
    log_success "mise installed: $(mise --version)"
  else
    die "mise installation completed but command not found"
  fi
}

install_dev_tools() {
  log_info "Installing development tools..."

  if ! command_exists mise; then
    die "mise not available - installation may have failed"
  fi

  eval "$(mise env -s bash)" 2>/dev/null || true
  eval "$(mise activate bash)" 2>/dev/null || true

  mise prune --yes || log_warn "mise prune failed, continuing anyway"

  if ! mise install; then
    die "Development tools installation failed"
  fi

  log_info "Upgrading mise tools to latest versions..."
  mise upgrade --yes || log_warn "mise upgrade failed, continuing anyway"

  eval "$(mise env -s bash)" 2>/dev/null || true
  log_success "Development tools installed"
}

setup_zsh_shell() {
  local platform="$1"

  log_info "Setting up zsh as default shell..."

  local zsh_path
  case "$platform" in
  macos)
    zsh_path="$(brew --prefix)/bin/zsh"
    ;;
  fedora | ubuntu)
    zsh_path="/usr/bin/zsh"
    ;;
  esac

  if [[ ! -x "$zsh_path" ]]; then
    die "zsh not found at $zsh_path"
  fi

  # Check if already default (handle symlinks)
  local current_shell
  current_shell="$(readlink -f "$SHELL" 2>/dev/null || echo "$SHELL")"
  local target_shell
  target_shell="$(readlink -f "$zsh_path" 2>/dev/null || echo "$zsh_path")"

  if [[ "$current_shell" == "$target_shell" ]]; then
    log_success "zsh is already the default shell"
    return 0
  fi

  # Add to /etc/shells if needed
  if ! grep -qx "$zsh_path" /etc/shells 2>/dev/null; then
    log_info "Adding zsh to /etc/shells (requires sudo)..."
    if ! echo "$zsh_path" | sudo tee -a /etc/shells >/dev/null; then
      die "Failed to add zsh to /etc/shells"
    fi
  fi

  log_info "Changing default shell to zsh (may require password)..."
  if ! chsh -s "$zsh_path"; then
    die "Failed to change default shell to zsh"
  fi

  log_success "Default shell changed to zsh"
}

main() {
  log_info "Running system setup..."
  log_info "Environment: $CHEZMOI_ENV"

  local platform
  platform="$(detect_platform)"
  log_info "Platform: $platform"

  if [[ "$platform" == "macos" ]]; then
    setup_homebrew
  fi

  install_system_packages "$platform"
  configure_rbw
  install_opencode "$platform"
  install_mise "$platform"
  install_dev_tools
  refresh_shell_environment "$platform"
  setup_zsh_shell "$platform"

  echo ""
  log_success "System setup complete!"
  echo ""
  echo "Next step: Run 'sudo reboot' to activate zsh and complete setup."
}

main "$@"
